<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Link Child | SEA Parent Portal</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css" />
</head>
<body class="link-page">
  <header class="dash-topbar">
    <div class="container dash-nav">
      <div class="brand">
        <div class="logo">SEA</div>
        <div>
          <h1>Link Child</h1>
          <p>Parent Portal</p>
        </div>
      </div>
      <a href="parent-dashboard.html" class="btn secondary">Back to Dashboard</a>
    </div>
  </header>

  <main class="container link-main">
    <section class="dash-hero">
      <span class="pill">Verify student access</span>
      <h2>Connect your child to your account</h2>
      <p>
        Enter the child’s details to unlock attendance, updates, notices, and teacher communication.
      </p>
    </section>

    <section class="link-card">
      <form id="linkForm" class="link-form">
        <div class="field">
          <label for="studentName">Child Name</label>
          <input type="text" id="studentName" placeholder="Enter child name" required>
        </div>

        <div class="field">
          <label for="studentId">Student / Access ID</label>
          <input type="text" id="studentId" placeholder="Enter student ID or access ID" required>
        </div>

        <div class="field">
          <label for="accessPassword">Access Password</label>
          <input type="password" id="accessPassword" placeholder="Enter access password" required>
        </div>

        <div class="field">
          <label for="relationship">Relationship</label>
          <select id="relationship" required>
            <option value="">Select relation</option>
            <option value="Father">Father</option>
            <option value="Mother">Mother</option>
            <option value="Guardian">Guardian</option>
          </select>
        </div>

        <button type="submit" class="btn primary">Link Child</button>
        <p id="linkMessage" class="toast"></p>
      </form>
    </section>
  </main>

  <script src="script.js"></script>
</body>
</html>
